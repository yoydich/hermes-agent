# ── Hermes Agent connection ────────────────────────────────────────────────────
# Gateway HTTP API (hermes-agent service, Railway private networking).
# In Railway: http://<hermes-agent-service-name>.railway.internal:8642
HERMES_API_URL=http://hermes-agent.railway.internal:8642

# Must match API_SERVER_KEY set on the hermes-agent service.
HERMES_API_TOKEN=

# Optional — enables enhanced file/memory/session features via dashboard API.
# In Railway: http://<hermes-agent-service-name>.railway.internal:9119
# HERMES_DASHBOARD_URL=http://hermes-agent.railway.internal:9119

# ── Security ───────────────────────────────────────────────────────────────────
# Required for any non-loopback deployment (Railway = non-loopback).
# Must be 32+ characters. Generate: openssl rand -base64 32
HERMES_PASSWORD=

# Required when behind Railway's proxy.
TRUST_PROXY=1

# Force Secure flag on session cookies (set to 1 for HTTPS deployments).
COOKIE_SECURE=1

# ── Server ─────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically; keep this commented out.
# PORT=3002
HOST=0.0.0.0
